var r := leia_inteiro
var t := 0
enquanto r > 0 faça
  var saldo := 0
  para i de 1 até r faça
    rodada = leia_inteiros(" ")
    saldo := saldo + rodada[1] - rodada[2]
  fim
  t := t + 1
  escreva "Teste {t}"
  escreva se saldo > 0 então "Aldo" senão "Beto" fim
  escreva ""
  r := leia_inteiro
fim
