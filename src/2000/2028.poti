var casos := 0
var entrada := leia_texto
enquanto não eof faça
  n = entrada.inteiro
  casos := casos + 1
  saida = 0 :: para i de 1 até n, j de 1 até i gere i fim
  tamanho = saida.tamanho
  escreva "Caso {casos}: {tamanho} {se tamanho < 2 então "numero" senão "numeros" fim}"
  escreva saida.junte(" ")
  escreva ""
  entrada := leia_texto
fim
