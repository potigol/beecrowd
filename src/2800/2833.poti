confronto(a, b, n: Inteiro) =
  ((a - 1) mod n - (n - 1) / 2) * ((b - 1) mod n - (n - 1) / 2) < 0

jogadores = leia_inteiros(" ")
kung = jogadores.posicao(1)
lu = jogadores.posicao(9)
se confronto(kung, lu, 16) então
  escreva "final"
senãose confronto(kung, lu, 8) então
  escreva "semifinal"
senãose confronto(kung, lu, 4) então
  escreva "quartas"
senão
  escreva "oitavas"
fim
