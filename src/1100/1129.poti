var n := leia_inteiro
enquanto n > 0 faça
  para i de 1 até n faça
    respostas = leia_inteiros(" ").mapeie(_ <= 127)
    pretos = respostas.selecione(_ == verdadeiro).tamanho
    se pretos == 1 então
      escreva "ABCDE"[respostas.posicao(verdadeiro)]
    senão
      escreva "*"
    fim
  fim
  n := leia_inteiro
fim
