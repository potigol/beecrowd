n = leia_inteiro
para i de 1 até n faça
  a = leia_inteiros(" ")
  hora, minuto, porta = a[1], a[2], a[3]
  horario = "{hora formato "%02d"}:{minuto formato "%02d"}"
  se porta == 1 então
    escreva "{horario} - A porta abriu!"
  senão
    escreva "{horario} - A porta fechou!"
  fim
fim
