var k := leia_inteiro
enquanto k > 0 faça
  a = leia_inteiros(" ")
  n, m = a[1], a[2]
  para i de 1 até k faça
    b = leia_inteiros(" ")
    dx, dy = b[1] - n, b[2] - m
    se   dx == 0 ou dy == 0 então escreva "divisa"
    senãose dx > 0 e dy > 0 então escreva "NE"
    senãose dx > 0          então escreva "SE"
    senãose          dy > 0 então escreva "NO"
    senão                         escreva "SO"
    fim
  fim
  k := leia_inteiro
fim
