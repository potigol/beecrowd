salario = leia_real

percentual = escolha salario
  caso s se s <=  400.00 => 15
  caso s se s <=  800.00 => 12
  caso s se s <= 1200.00 => 10
  caso s se s <= 2000.00 =>  7
  caso _                 =>  4
fim

reajuste = salario * percentual / 100
novo_salario = salario + reajuste

escreva "Novo salario: {novo_salario formato "%.2f"}"
escreva "Reajuste ganho: {reajuste formato "%.2f"}"
escreva "Em percentual: {percentual} %"