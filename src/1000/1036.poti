valores = leia_reais(" ")
a, b, c = valores[1], valores[2], valores[3]
delta = b ^ 2 - 4 * a * c
se a == 0 ou delta < 0 então
  escreva "Impossivel calcular"
senão
  r1 = ((-b) + raiz(delta)) / (2 * a)
  r2 = ((-b) - raiz(delta)) / (2 * a)
  escreva "R1 = {r1 formato "%.5f"}"
  escreva "R2 = {r2 formato "%.5f"}"
fim
