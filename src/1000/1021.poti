n = leia_real
n_int = n.inteiro
n_moedas = ((n - n_int + n_int mod 5 mod 2) * 100).arredonde

notas = [100, 50, 20, 10, 5, 2]
moedas = [100, 50, 25, 10, 5, 1]

f(a, v: Inteiro, l: Lista[Inteiro]) = (l.pegue(a - 1).injete(v)(_ mod _)) div l[a]

escreva "NOTAS:"
para i de 1 até 6 faça
  escreva "{f(i, n_int, notas)} nota(s) de R$ {notas[i]}.00"
fim

escreva "MOEDAS:"
para i de 1 até 6 faça
  escreva "{f(i, n_moedas, moedas)} moeda(s) de R$ {(moedas[i]/100) formato "%.2f"}"
fim