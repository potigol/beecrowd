lados = leia_inteiros(" ").ordene
a, b, c = lados[1], lados[2], lados[3]
se a + b > c então
  imprima "Valido-"
  escreva se a == c então
    "Equilatero"
  senãose a == b ou b == c então
    "Isoceles"
  senão
    "Escaleno"
  fim
  escreva "Retangulo: {se a * a + b * b == c * c então "S" senão "N" fim}"
senão
  escreva "Invalido"
fim
