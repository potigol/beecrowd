var d := leia_texto
enquanto não eof faça
  s = leia_texto
  var i := 0
  enquanto i < d.tamanho - s.tamanho + 1 faça
    se d.descarte(i).pegue(s.tamanho) == s então
      escreva "Resistente"
      i := d.tamanho
    senão
      i := i + 1
    fim
  fim
  se i < d.tamanho então
    escreva "Nao resistente"
  fim
  d := leia_texto
fim
