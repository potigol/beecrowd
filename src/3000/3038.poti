var linha := leia_texto
enquanto nao eof faca
  saida = para c em linha.lista gere
    escolha c
      caso  c  se não "@&!*#".contém(c) =>  c
      caso '&' => 'e'
      caso '!' => 'i'
      caso '*' => 'o'
      caso '#' => 'u'
      caso  _  => 'a'
    fim
  fim
  escreva saida.junte("")
  linha := leia_texto
fim
