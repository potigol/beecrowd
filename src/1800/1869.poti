digito(n: BigInt) =
  se n > 9 então (n.toInt + 55).caractere senão (n.toInt + 48).caractere fim

base32(n: BigInt): Texto =
  se n > 0 então base32(n div 32) + digito(n mod 32) senão "" fim

var a := BigInt(1)
enquanto a > 0 faça
  a := BigInt(leia_texto)
  se a > 0 então escreva base32(a) senão escreva 0 fim
fim
