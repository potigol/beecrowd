entrada = leia_textos(" ")
a = entrada[1].lista.mapeie(a => se a == '7' então '0' senão a fim).junte("").inteiro
b = entrada[3].lista.mapeie(a => se a == '7' então '0' senão a fim).junte("").inteiro
c = se entrada[2] == "+" então a + b senão a * b fim
escreva c.texto.lista.mapeie(a => se a == '7' então '0' senão a fim).junte("").inteiro
