tipo Ser
  nome: Texto
  poder, kill, morte: Inteiro
fim

lt = (s1, s2: Ser) =>
  se s1.poder <> s2.poder então s1.poder > s2.poder
  senãose s1.kill <> s2.kill então s1.kill > s2.kill
  senãose s1.morte <> s2.morte então s1.morte < s2.morte
  senão s1.nome < s2.nome
  fim

n = leia_inteiro
seres = para i de 1 até n gere
  a = leia_textos(" ")
  Ser(a[1], a[2].inteiro, a[3].inteiro, a[4].inteiro)
fim
godofor = seres.ordene(lt).cabeca
escreva godofor.nome
