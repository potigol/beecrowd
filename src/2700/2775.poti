var n := leia_inteiro
enquanto n > 0 faça
  p, v = leia_inteiros(" ")
  var m = p.zip(v).mutável
  var soma := 0
  var alterado := verdadeiro
  enquanto alterado faça
    alterado := falso
    para i de 1 até n - 1 faça
      se m[i].primeiro > m[i+1].primeiro então
        soma := soma + m[i].segundo + m[i+1].segundo
        aux = m[i]
        m[i] := m[i+1]
        m[i+1] := aux
        alterado := verdadeiro
      fim
    fim
  fim
  escreva soma
  n := leia_inteiro
fim
