n = leia_inteiro
para i de 1 até n faça
  s = leia_texto
  a = s.minusculo.divida_quando((x, y) => "aeiou" - "{x}" <> "aeiou" ou "aeiou" - "{y}" <> "aeiou")
  b = a.ordene(_.tamanho).ultimo.tamanho
  se b >= 3 então
    escreva "{s} nao eh facil"
  senão
    escreva "{s} eh facil"
  fim
fim
