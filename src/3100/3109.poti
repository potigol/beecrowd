n, q = leia_inteiro
var emp := para i de 1 até n gere i fim
para i de 1 até q faça
  f = leia_inteiros(" ")
  se f[1] == 1 então
    a, b = f[2], f[3]
    aux = emp[a]
    emp[a] := emp[b]
    emp[b] := aux
  senão
    var c := 0
    var p := f[2]
    enquanto f[2] <> emp[p] faça
      c := c + 1
      p := emp[p]
    fim
    escreva c
  fim
fim
