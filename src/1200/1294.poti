def min(a, b: Real) = se a < b então a senao b fim
def real(a: Texto) = a.real

var saida: Lista[Texto] := []

var entrada := leia_texto
enquanto não eof faça
    a = entrada.divida(" ").mapeie(real)
    l, w = a[1], a[2]
    menor = min(l, w) / 2
    r = - raiz((l - w) ^ 2 + l * w) / 6 + (l + w) / 6
    saida := "{r formato "%.3f"} 0.000 {menor formato "%.3f"}" :: saida
    entrada := leia_texto
fim
escreva saida.inverta.junte("\n")
