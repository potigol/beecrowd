var n := leia_inteiro
enquanto não eof faça
  var esq, dir := Lista(31, 0)
  para i de 1 até n faça
    a = leia_textos(" ")
    x = a[1].inteiro - 29
    se a[2] == "E" então
      esq[x] := esq[x] + 1
    senão
      dir[x] := dir[x] + 1
    fim
  fim
  pares = esq.zip(dir).mapeie(
    a => se a.primeiro < a.segundo então a.primeiro senão a.segundo fim
 ).injete(0)(_ + _)
  escreva pares
  n := leia_inteiro
fim
