var dolares := leia_inteiro
enquanto não eof faça
  centavos = leia_inteiro
  s0 = dolares.texto
  s1 = se s0.tamanho > 3  então s0.insira(s0.tamanho - 2 , ',') senão s0 fim
  s2 = se s1.tamanho > 7  então s1.insira(s1.tamanho - 6 , ',') senão s1 fim
  s3 = se s2.tamanho > 11 então s2.insira(s2.tamanho - 10, ',') senão s2 fim
  escreva "${s3}.{centavos formato "%02d"}"
  dolares := leia_inteiro
fim
