var n := leia_inteiro
enquanto n > 0 faça
  var a, b := 0
  para i de 1 até n faça
    jogo = leia_texto
    se jogo.tamanho == 3 então
      se jogo[1] > jogo[3] então a := a + 1 fim
      se jogo[1] < jogo[3] então b := b + 1 fim
    senãose jogo.tamanho == 4 então
      se jogo[3] == ' ' então
        a := a + 1
      senão
        b := b + 1
      fim
    fim
  fim
  escreva "{a} {b}"
  n := leia_inteiro
fim
