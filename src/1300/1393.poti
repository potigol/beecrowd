lajotas(a: Lista[Inteiro]): Lista[Inteiro] =
  se      a.tamanho < 2   então lajotas([2, 1])
  senãose a.tamanho >= 40 então a.inverta
  senão                         lajotas((a[1] + a[2]) :: a)
  fim

l = lajotas([])

var n := leia_inteiro
enquanto n > 0 faça
  escreva l[n]
  n := leia_inteiro
fim
